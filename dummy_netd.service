[Unit]
Description=A simple dummy netd service implementation.
After=droid-hal-init.service
Before=ofono.service

[Service]
Type=notify
EnvironmentFile=-/etc/sysconfig/dummy_netd
ExecStart=/usr/sbin/dummy_netd $DUMMY_NETD_ARGS
Restart=always
TimeoutStartSec=60
# Sandboxing
CapabilityBoundingSet=CAP_DAC_READ_SEARCH
DeviceAllow=/dev/binder rw
DeviceAllow=/dev/hwbinder rw
DevicePolicy=strict
NoNewPrivileges=yes
PrivateNetwork=true
PrivateTmp=yes
ProtectHome=yes
ProtectSystem=full

[Install]
WantedBy=graphical.target

